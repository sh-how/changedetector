# Copy this file to `.env` and fill in your real values.
# `.env` is gitignored and must never be committed.
#
# Create a bot with @BotFather in Telegram to get the token.
# Get your chat id by messaging the bot, then visiting:
#   https://api.telegram.org/bot<TOKEN>/getUpdates
# and reading result[].message.chat.id
CHANGEDETECTOR_TELEGRAM_BOT_TOKEN=
CHANGEDETECTOR_TELEGRAM_CHAT_ID=
